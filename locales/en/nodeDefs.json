{
  "SCAIL2ColoredMaskV2": {
    "display_name": "Create SCAIL-2 Colored Mask V2",
    "inputs": {
      "driving_track_data": {
        "name": "driving track data",
        "tooltip": "SAM3 track of the driving pose video. Will be rendered into the pose_video_mask output."
      },
      "ref_track_data": {
        "name": "reference track data",
        "tooltip": "SAM3 track of the reference image."
      },
      "prefix_track_data": {
        "name": "prefix track data",
        "tooltip": "SAM3 track of a prefix image batch. The first 5 frames are rendered into prefix_image_mask."
      },
      "object_indices": {
        "name": "object indices",
        "tooltip": "Comma-separated list of person indices to include. Empty = all."
      },
      "sort_by": {
        "name": "sort by",
        "tooltip": "Order in which palette colors are assigned to tracked objects."
      },
      "prefix_mask_mode": {
        "name": "prefix mask mode",
        "tooltip": "Controls how colors are assigned to the prefix image mask batch."
      },
      "replacement_mode": {
        "name": "replacement mode",
        "tooltip": "False = animation mode. True = replacement mode."
      },
      "render_device": {
        "name": "render device",
        "tooltip": "Device used to render the RGB mask tensors."
      }
    },
    "outputs": {
      "0": {
        "name": "pose video mask"
      },
      "1": {
        "name": "reference image mask"
      },
      "2": {
        "name": "prefix image mask"
      }
    }
  },
